      ]
    },
    {
      "name": "05. Editor Listings (editor token)",
      "item": [
        {
          "name": "Create Listing (state-changing)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Pending listing was created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set(\"editorListingId\", pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{editorAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman family home in DHA Phase 6\",\n  \"description\": \"A realistically described local demo listing created through Postman for the review workflow.\",\n  \"city_id\": {{cityId}},\n  \"address\": \"House 42, DHA Phase 6, Lahore\",\n  \"price\": 28500000,\n  \"property_type\": \"house\"\n}",
              "options": {
                "raw": {
                  "language": "json"
