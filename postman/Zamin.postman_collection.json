    {
      "name": "02. Public",
      "item": [
        {
          "name": "List Public Cities",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Cities returned\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    const city = body.items.find(function (item) { return item.name === \"Lahore\"; }) || body.items[0];",
                  "    if (city) { pm.collectionVariables.set(\"cityId\", city.id); }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/cities?page=1&page_size=50",
            "description": "Sets cityId to Lahore when present, otherwise to the first active city."
          }
        },
        {
          "name": "Search Approved Listings",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Public listing search succeeded\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    if (body.items && body.items.length > 0) {",
                  "        pm.collectionVariables.set(\"publicListingId\", body.items[0].id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/listings?city=Lahore&q=Gulberg&search_mode=contains&page=1&page_size=20",
            "description": "Searches only approved listings and stores the first result as publicListingId."
          }
        },
        {
          "name": "Get Public Listing",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/listings/{{publicListingId}}",
            "description": "Send Search Approved Listings first, or set publicListingId manually."
          }
        }
      ]
    },
    {
