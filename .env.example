# Keep this file as a template only. Do not commit real secrets.
DATABASE_URL=sqlite:///./real_estate.db
MEDIA_ROOT=./media
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
API_V1_PREFIX=/api/v1
AUTO_CREATE_SCHEMA=false

# Seeded only when no admin exists. Alternatively use: python -m app.cli seed-admin ...
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_FULL_NAME=Platform Admin
ADMIN_PHONE_NUMBER=+923001234567

ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=30
MAX_IMAGES_PER_LISTING=10
MAX_IMAGE_BYTES=5242880
MAX_FUZZY_CANDIDATES=2000
